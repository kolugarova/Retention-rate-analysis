--data from cohort_users_raw
SELECT *
FROM 
	ads_analysis_goit_course.project.cohort_users_raw as cur 
limit 
	10;

----data from cohort_events_raw
SELECT *
FROM 
	ads_analysis_goit_course.project.cohort_events_raw as cer 
limit 
	10;

--крок 1 сте по регістрації
WITH users_signup AS (
SELECT
    cur.user_id,
    cur.promo_signup_flag,
    cur.signup_datetime,
	CASE

    -- крок 1: рік 4 цифри
    WHEN LENGTH(SPLIT_PART(
            REPLACE(REPLACE(SPLIT_PART(TRIM(cur.signup_datetime), ' ', 1), '/', '-'), '.', '-'),
        '-', 3)) = 4
    THEN TO_DATE(
        REPLACE(REPLACE(SPLIT_PART(TRIM(cur.signup_datetime), ' ', 1), '/', '-'), '.', '-'),
        'DD-MM-YYYY'
    )
    -- крок 2: рік 2 цифри
    WHEN LENGTH(SPLIT_PART(
            REPLACE(REPLACE(SPLIT_PART(TRIM(cur.signup_datetime), ' ', 1), '/', '-'), '.', '-'),
        '-', 3)) = 2
    THEN TO_DATE(
        REPLACE(REPLACE(SPLIT_PART(TRIM(cur.signup_datetime), ' ', 1), '/', '-'), '.', '-'),
        'DD-MM-YY'
    )
    ELSE NULL
    END AS signup_ts

FROM ads_analysis_goit_course.project.cohort_users_raw cur
)
SELECT * FROM users_signup;


